# ポッドキャスト機能の環境変数設定例
# このファイルを .env.podcast にコピーして実際の値を設定してください

# =============================================
# ポッドキャスト機能の基本設定
# =============================================

# ポッドキャスト機能を有効にする
ENABLE_PODCAST_GENERATION=true

# =============================================
# LINE Messaging API 設定
# =============================================

# LINE Developers Console から取得
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here
LINE_CHANNEL_SECRET=your_line_channel_secret_here

# =============================================
# ポッドキャスト配信設定
# =============================================

# GitHub Pages のベースURL（実際のURLに変更）
PODCAST_RSS_BASE_URL=https://your-username.github.io/your-repository

# ポッドキャスト情報
PODCAST_RSS_TITLE=マーケットニュース10分
PODCAST_RSS_DESCRIPTION=AIが生成する毎日のマーケットニュースポッドキャスト
PODCAST_AUTHOR_NAME=Your Name
PODCAST_AUTHOR_EMAIL=your-email@example.com
PODCAST_LANGUAGE=ja

# =============================================
# 音声設定
# =============================================

# 音声品質設定
PODCAST_TARGET_DURATION_MINUTES=10.0
PODCAST_MAX_FILE_SIZE_MB=15
PODCAST_AUDIO_FORMAT=mp3
PODCAST_SAMPLE_RATE=44100
PODCAST_BITRATE=128k

# 音量正規化設定
PODCAST_LUFS_TARGET=-16.0
PODCAST_PEAK_TARGET=-1.0

# =============================================
# AI/TTS設定
# =============================================

# 台本生成用モデル（高性能）
PODCAST_SCRIPT_MODEL=gemini-2.5-pro

# TTS音声合成モデル
PODCAST_TTS_MODEL=gemini-tts

# 台本の文字数制御
PODCAST_TARGET_CHARACTER_COUNT_MIN=2400
PODCAST_TARGET_CHARACTER_COUNT_MAX=2800

# =============================================
# コスト管理
# =============================================

# 月額コスト制限（USD）
PODCAST_MONTHLY_COST_LIMIT=10.0

# =============================================
# ディレクトリ設定
# =============================================

# 出力ディレクトリ
PODCAST_RSS_OUTPUT_DIR=./output/rss
PODCAST_AUDIO_OUTPUT_DIR=./output/audio

# =============================================
# 配信スケジュール設定
# =============================================

# ポッドキャスト生成時刻（JST）
PODCAST_GENERATION_HOUR=5
PODCAST_GENERATION_MINUTE=0

# 配信曜日設定（0=月曜, 1=火曜, ..., 6=日曜）
PODCAST_ENABLED_WEEKDAYS=0,1,2,3,4  # 月曜から金曜まで

# =============================================
# エピソード設定
# =============================================

# エピソード番号の接頭辞・接尾辞
PODCAST_EPISODE_PREFIX=第
PODCAST_EPISODE_SUFFIX=回

# =============================================
# デバッグ・テスト設定
# =============================================

# テストモード（本番配信を行わない）
PODCAST_TEST_MODE=false

# 詳細ログ出力
PODCAST_DEBUG_LOGGING=false

# =============================================
# オプション設定
# =============================================

# S3フォールバック設定（オプション）
# PODCAST_S3_BUCKET=your-s3-bucket-name
# PODCAST_S3_ACCESS_KEY=your-s3-access-key
# PODCAST_S3_SECRET_KEY=your-s3-secret-key
# PODCAST_S3_REGION=us-east-1

# Webhook URL（オプション）
# PODCAST_WEBHOOK_URL=https://your-webhook-url.com/podcast

# カスタムプロンプト（オプション）
# PODCAST_CUSTOM_PROMPT_TEMPLATE=your-custom-prompt-template